class Solution {
    public int getSecondLargest(int[] arr) {
        long max = 0;
        long secmax = 0;
        for(int i:arr)
        {
            if(i>max)
            {
                secmax = max;
                max = i;
            }
            else if(i>secmax && i!=max)
            {
                secmax = i;
            }
        }
        return (secmax==0)?-1:(int)secmax;
    }
}
